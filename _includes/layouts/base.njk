<!doctype html>
<html lang="{{ metadata.language }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {# Uden JS må intet indhold gemmes væk: .reveal skjuler kun under html.js #}
  <script>document.documentElement.classList.add("js");</script>
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/img/favicon-16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/favicon-180.png">
  <title>{% if title %}{{ title }} · {{ metadata.title }}{% else %}{{ metadata.title }} — {{ metadata.tagline }}{% endif %}</title>
  <meta name="description" content="{{ description or metadata.description }}">
  {%- set ogimg = image if image else "/assets/img/bigaard-hero.jpg" %}
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ metadata.title }}">
  <meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ metadata.title }} — {{ metadata.tagline }}{% endif %}">
  <meta property="og:description" content="{{ description or metadata.description }}">
  <meta property="og:image" content="{{ ogimg | htmlBaseUrl(metadata.url) }}">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preload" href="/assets/fonts/fraunces-300-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/fraunces-900-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/assets/css/site.css">
  <link rel="alternate" type="application/rss+xml" href="/feed.xml" title="{{ metadata.title }}">
</head>
<body>
  <a class="skip-link" href="#indhold">Spring til indhold</a>
  {% include "partials/nav.njk" %}
  <main id="indhold">
    {{ content | safe }}
  </main>
  {% include "partials/footer.njk" %}
  <script src="/assets/js/reveal.js" defer></script>
  <script src="/assets/js/nav.js" defer></script>
  {# anonym besøgstælling — ingen cookies, localhost ignoreres af GoatCounter selv #}
  <script data-goatcounter="https://henrikshonning.goatcounter.com/count"
          async src="//gc.zgo.at/count.js"></script>
</body>
</html>
