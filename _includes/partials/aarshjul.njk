<section class="season" id="aaret">
  <!-- halmkube-skitse i baggrunden -->
  {% include "partials/illustrationer/halmkube.njk" %}
  <div class="season-inner">
    <span class="label reveal">Årshjulet</span>
    <h2 class="reveal">Bigården <em>gennem året</em></h2>
    <div class="timeline">
      <div class="tl-item reveal">
        <span class="when">Marts – April</span>
        <h4>Forårseftersyn</h4>
        <p>Vinterklyngen løsner sig, dronningen lægger igen æg, og biavleren kigger til familierne for første gang.</p>
      </div>
      <div class="tl-item reveal">
        <span class="when">Maj – Juni</span>
        <h4>Sværmtid &amp; forårstræk</h4>
        <p>Familien vokser eksplosivt. Raps og frugttræer giver årets første honning — og sværmene skal forebygges.</p>
      </div>
      <div class="tl-item reveal">
        <span class="when">Juli – August</span>
        <h4>Honninghøst</h4>
        <p>Sommerens nektar slynges og kommer på glas. Efter høsten behandles familierne mod varroamiden.</p>
      </div>
      <div class="tl-item reveal">
        <span class="when">September – Februar</span>
        <h4>Vinterklyngen</h4>
        <p>Bierne fodres ind og samler sig i klynge om dronningen. Nu handler alt om ro, foder og tætte stader.</p>
      </div>
    </div>
  </div>
</section>
