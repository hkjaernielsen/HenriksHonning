<figure class="margin-plate reveal">
  <svg viewBox="0 0 300 420" aria-label="Botanisk studie af hvidkløver">
    <defs>
      <pattern id="crosshatch3" width="7" height="7" patternUnits="userSpaceOnUse" patternTransform="rotate(38)">
        <line x1="0" y1="0" x2="0" y2="7" stroke="#6b5334" stroke-width=".7" opacity=".4"/>
      </pattern>
      <filter id="rough2"><feTurbulence type="fractalNoise" baseFrequency="0.03" numOctaves="2" result="n"/><feDisplacementMap in="SourceGraphic" in2="n" scale="2"/></filter>
    </defs>
    <ellipse cx="150" cy="205" rx="138" ry="192" fill="#efe7d3" opacity=".6"/>
    <g filter="url(#rough2)">
      <!-- stængel -->
      <path class="sketch animate-draw" d="M150 392 C 148 330, 154 270, 146 210 C 142 178, 146 140, 152 118" stroke-width="2"/>
      <!-- blade (trekløver) -->
      <g class="sketch" stroke-width="1.5">
        <path class="animate-draw" d="M146 300 C 118 296, 96 280, 92 258 C 110 252, 136 262, 146 282 Z" fill="url(#crosshatch3)"/>
        <path class="animate-draw" d="M148 296 C 150 268, 142 244, 124 232 C 112 250, 118 278, 138 294 Z"/>
        <path class="animate-draw" d="M150 300 C 176 292, 194 274, 196 252 C 176 248, 154 262, 150 284 Z" fill="url(#crosshatch3)"/>
      </g>
      <!-- blomsterhoved: mange små kroner -->
      <g class="sketch" stroke-width="1.2">
        <ellipse class="animate-draw" cx="152" cy="94" rx="42" ry="36"/>
        <path d="M120 80 C 126 70, 136 64, 148 62 M132 108 C 124 100, 118 92, 118 82 M158 60 C 170 62, 180 68, 186 78 M184 96 C 182 106, 174 114, 164 118 M146 122 C 152 116, 158 112, 166 110 M136 70 l6 8 M156 66 l2 10 M172 78 l-6 8 M176 96 l-9 4 M128 92 l10 2 M144 108 l4 -8 M162 104 l-2 -9"/>
        <path d="M152 94 m-8 -4 a8 8 0 1 1 0 .1" stroke-width=".9" opacity=".6"/>
      </g>
      <!-- lille bi på vej mod blomsten -->
      <g class="sketch" stroke-width="1.3">
        <ellipse class="animate-draw" cx="232" cy="140" rx="13" ry="9"/>
        <path d="M225 136 h14 M224 140 h16 M225 144 h14" stroke-width="1"/>
        <path class="animate-draw" d="M226 128 C 218 118, 206 114, 196 116 M238 128 C 246 118, 258 114, 268 116" stroke-width="1"/>
        <path class="sketch-faint" d="M218 152 C 200 170, 186 118, 168 132 C 160 138, 164 148, 158 96" stroke-width=".8" stroke-dasharray="2 6"/>
      </g>
      <!-- annotationer -->
      <text class="annot" x="42" y="240" font-size="13">trifolium repens</text>
      <path class="sketch-faint" d="M96 246 C 108 252, 118 258, 126 264" stroke-width=".7" stroke-dasharray="1 5"/>
      <text class="annot" x="150" y="404" font-size="14" text-anchor="middle" letter-spacing=".06em">hvidkløver — biernes spisekammer</text>
    </g>
  </svg>
  <figcaption>Studieblad · trækplanter i det åbne land</figcaption>
</figure>
